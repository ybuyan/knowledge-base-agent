  "name": "转正流程",
  "category": "转正",
  "steps": [
    {
      "step_number": 1,
      "action": "员工试用期满前提交转正申请（或系统自动触发）",
      "responsible_person": "员工本人",
      "estimated_time": "即时",
      "notes": "需在试用期结束前至少3个工作日提出"
    },
    {
      "step_number": 2,
      "action": "部门主管开展转正考核与评估，填写转正审批意见",
      "responsible_person": "直属主管",
      "estimated_time": "1个工作日",
      "notes": "依据工作表现、目标达成、团队协作等维度综合评价；需明确是否同意转正及理由"
    },
    {
      "step_number": 3,
      "action": "人力资源部审核转正资格及材料完整性",
      "responsible_person": "人力资源部",
      "estimated_time": "半个工作日",
      "notes": "核查试用期时长、考勤记录、考核结果、劳动合同约定等"
    },
    {
      "step_number": 4,
      "action": "HR办理转正手续：更新劳动合同状态、薪资档案、系统权限等",
      "responsible_person": "人力资源部",
      "estimated_time": "半个工作日",
      "notes": "同步通知员工及用人部门转正生效日期"
    }
  ],
  "materials": [
    {
      "material_name": "转正申请书",
      "is_required": true,
      "description": "员工本人提交的书面/系统转正申请",
      "example": "本人于2024年6月1日入职，试用期至2024年8月31日，现申请按期转正。",
      "form_link": "https://hr.example.com/form/transfer-approval"
    },
    {
      "material_name": "转正考核表",
      "is_required": true,
      "description": "由直属主管填写的绩效与胜任力评估表",
      "example": "工作质量：优秀；任务完成率：100%；沟通协作：良好；综合评定：同意转正",
      "form_link": "https://hr.example.com/form/transfer-evaluation"
    },
    {
      "material_name": "试用期工作总结",
      "is_required": false,
      "description": "员工对试用期内工作内容、成果及改进点的简要总结",
      "example": "完成XX项目需求分析与原型设计；独立承担3次客户演示；参与部门知识库建设。",
      "form_link": "https://hr.example.com/form/probation-summary"
    }
  ],
