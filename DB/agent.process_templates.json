  "name": "请假申请流程",
  "category": "请假",
  "steps": [
    {
      "step_number": 1,
      "action": "员工填写请假申请表，注明请假类型、时间、原因",
      "responsible_person": "员工",
      "estimated_time": "即时",
      "notes": "年假需提前3天申请；紧急情况可先电话请假，后补手续"
    },
    {
      "step_number": 2,
      "action": "提交直属主管审批",
      "responsible_person": "直属主管",
      "estimated_time": "1个工作日内",
      "notes": ""
    },
    {
      "step_number": 3,
      "action": "主管审批通过后，提交HR部门审核",
      "responsible_person": "HR部门",
      "estimated_time": "1个工作日内",
      "notes": ""
    },
    {
      "step_number": 4,
      "action": "HR审核通过后，系统自动通知员工",
      "responsible_person": "HR系统",
      "estimated_time": "即时",
      "notes": ""
    }
  ],
  "materials": [
    {
      "material_name": "请假申请表",
      "is_required": true,
      "description": "填写请假类型、时间、原因等信息",
      "example": "事假/病假/年假，2024-05-10至2024-05-12，感冒发烧",
      "form_link": ""
    },
    {
      "material_name": "医院证明",
