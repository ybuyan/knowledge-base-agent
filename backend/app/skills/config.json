{
  "version": "1.0",
  "skills": [
    {
      "id": "document_upload",
      "name": "文档上传处理",
      "description": "解析文档、切分文本、向量化存储",
      "enabled": true,
      "triggers": ["document_upload"],
      "pipeline": [
        {
          "step": "parse_document",
          "processor": "DocumentParser",
          "comment": "步骤1: 解析上传的文档，提取文本内容，支持多种格式（PDF、Word、Excel、图片等）",
          "params": {
            "supported_formats": ["pdf", "docx", "txt", "xlsx", "pptx", "png", "jpg", "jpeg", "gif", "bmp", "webp"]
          }
        },
        {
          "step": "split_text",
          "processor": "TextSplitter",
          "comment": "步骤2: 将提取的文本切分成小块，每块500字符，块之间重叠50字符以保持上下文连贯性",
          "params": {
            "chunk_size": 500,
            "chunk_overlap": 50,
            "split_by": "paragraph"
          }
        },
        {
          "step": "embed_chunks",
          "processor": "EmbeddingProcessor",
          "comment": "步骤3: 将每个文本块转换为向量表示（embedding），用于后续的语义检索",
          "params": {}
        },
        {
          "step": "store_vectors",
          "processor": "VectorStore",
          "comment": "步骤4: 将生成的向量批量存储到向量数据库的documents集合中，每批100条",
          "params": {
            "collection": "documents",
            "batch_size": 100
          }
        },
        {
          "step": "build_keyword_index",
          "processor": "KeywordIndexBuilder",
          "comment": "步骤5: 构建关键词索引，用于混合检索（向量检索+关键词检索）提升准确性",
          "params": {}
        }
      ],
      "output": {
        "return": ["document_id", "chunk_count", "status"]
      }
    },
    {
      "id": "qa_rag",
      "name": "RAG问答",
      "description": "检索增强生成问答",
      "enabled": true,
      "triggers": ["user_question"],
      "pipeline": [
        {
          "step": "embed_query",
          "processor": "EmbeddingProcessor",
          "comment": "步骤1: 将用户问题转换为向量表示，用于语义相似度检索",
          "params": {}
        },
        {
          "step": "retrieve_knowledge",
          "processor": "VectorRetriever",
          "comment": "步骤2: 从文档知识库中检索最相关的5个文本块，用于回答问题",
          "params": {
            "collection": "documents",
            "top_k": 5,
            "score_threshold": 0.0
          }
        },
        {
          "step": "retrieve_history",
          "processor": "VectorRetriever",
          "comment": "步骤3: 从历史对话中检索最相关的3条记录，提供上下文连贯性",
          "params": {
            "collection": "conversations",
            "top_k": 3
          }
        },
        {
          "step": "build_context",
          "processor": "ContextBuilder",
          "comment": "步骤4: 整合检索到的知识和历史对话，构建完整的上下文（最多4000 tokens），包含来源信息",
          "params": {
            "max_tokens": 4000,
            "include_sources": true
          }
        },
        {
          "step": "generate_answer",
          "processor": "LLMGenerator",
          "comment": "步骤5: 使用大语言模型基于构建的上下文生成答案，采用qa_rag提示词模板",
          "params": {
            "prompt_template": "qa_rag",
            "stream": false
          }
        },
        {
          "step": "store_conversation",
          "processor": "VectorStore",
          "comment": "步骤6: 将本次问答对话存储到conversations集合，用于后续的对话历史检索",
          "params": {
            "collection": "conversations"
          }
        }
      ],
      "output": {
        "return": ["answer", "sources", "conversation_id"]
      }
    }
  ]
}
