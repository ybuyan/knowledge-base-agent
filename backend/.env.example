# ===========================================
# AI Assistant Configuration
# ===========================================

# Application
APP_ENV=development
APP_DEBUG=true

# Security - REQUIRED in production
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-key-for-development-only-32ch

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM Configuration (通义千问)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# LLM 模型配置（实际使用）
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Embedding 模型配置
EMBEDDING_MODEL=text-embedding-v3

# Alternative: OpenAI compatible API
# LLM_API_KEY=your_api_key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4

# MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=ai-assistant

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# Memory
MEMORY_MAX_TOKENS=4000
MEMORY_MAX_SESSIONS=1000

# ===========================================
# MCP Resource Public Access Configuration
# ===========================================

# API Key Configuration
API_KEY_PREFIX=mcp_
API_KEY_DEFAULT_RATE_LIMIT=100
API_KEY_DEFAULT_EXPIRES_DAYS=365

# Rate Limiting
GLOBAL_RATE_LIMIT_PER_IP=300
RATE_LIMIT_WINDOW_SECONDS=60

# Audit Logging
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_BATCH_SIZE=100
AUDIT_LOG_BATCH_TIMEOUT=1.0

# Security
ENABLE_OAUTH2=false
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256

# Redis (Optional - for performance optimization)
# REDIS_URL=redis://localhost:6379/0
# REDIS_MAX_CONNECTIONS=50
